# =============================================================================
# Juddges App Environment Configuration - Example/Reference
# =============================================================================
# This file serves as a reference for all available configuration options.
#
# ACTUAL CONFIGURATION STRATEGY:
#   1. .env.defaults - Committed file with sensible defaults (already exists)
#   2. .env.local - Your local overrides (gitignored, create if needed)
#   3. .env.secrets - Your sensitive credentials (gitignored, create this)
#
# GETTING STARTED:
#   1. Copy this file to .env.secrets:
#      cp .env.example .env.secrets
#   2. Fill in your actual secret values in .env.secrets
#   3. Optionally create .env.local for non-secret local overrides
#
# DO NOT use this file directly - it's for reference only!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# Note: Supabase provides:
#   - PostgreSQL database with pgvector extension for semantic search
#   - Authentication and user management
#   - All vector search operations (replaces Weaviate)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Frontend uses anon key (client-side safe)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# -----------------------------------------------------------------------------
# OpenAI Configuration (for embeddings and AI features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo for cost savings

# Embedding model (for semantic search)
# DB schema uses 1024d vectors (vector(1024)) with BAAI/bge-m3.
# Query embeddings MUST come from the same model as ingested docs, otherwise
# cosine similarity is meaningless.
# Only provider registered (see backend/app/embedding_providers.py):
#   - tei/bge-m3  (1024d; BAAI/bge-m3 via remote TEI server)
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL_ID=tei/bge-m3

# TEI embedding provider (Text Embeddings Inference, HTTP)
# Hosts BGE-M3 remotely so the backend container stays lightweight.
TEI_EMBEDDING_URL=https://embeddings.lab.augustyniak.ai
TEI_VERIFY_SSL=false        # set true in prod (with trusted CA)
TEI_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8004
BACKEND_API_KEY=your-backend-api-key-here

# Meilisearch (autocomplete/search-as-you-type layer)
# MEILI_MASTER_KEY is REQUIRED in production (docker-compose will fail without it)
# Generate with: openssl rand -base64 32
MEILI_MASTER_KEY=your-meilisearch-master-key
# MEILISEARCH_URL should point to the Docker service name in container environments
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_SEARCH_KEY=your-meilisearch-search-key
MEILISEARCH_ADMIN_KEY=your-meilisearch-admin-key
MEILISEARCH_INDEX_NAME=judgments
MEILISEARCH_TIMEOUT_SECONDS=5

# API Rate Limits
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_PER_HOUR=1000

# -----------------------------------------------------------------------------
# Reverse proxy / deployment
# -----------------------------------------------------------------------------
# Set TRUSTED_PROXY=true when the backend runs behind a trusted reverse proxy
# (e.g. Caddy, nginx, Traefik) that injects X-Forwarded-For / X-Real-IP.
# When true, the rate limiter keys on the leftmost X-Forwarded-For IP
# (the real client) instead of the proxy's socket address.
# Leave false (the default) for direct-to-internet deployments where
# trusting these headers would allow clients to spoof their IP.
TRUSTED_PROXY=false

# -----------------------------------------------------------------------------
# Database Configuration (if running PostgreSQL separately)
# -----------------------------------------------------------------------------
# Note: Supabase provides managed PostgreSQL, so this is optional
DATABASE_URL=postgresql://user:password@localhost:5432/juddges_db

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Juddges App"
NEXT_PUBLIC_APP_URL=http://localhost:3007
NEXT_PUBLIC_API_URL=${BACKEND_URL}
AUTH_REDIRECT_ALLOWED_HOSTS=localhost:3007

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_EMBEDDINGS=true

# -----------------------------------------------------------------------------
# Error Tracking (Optional - Sentry)
# -----------------------------------------------------------------------------
# Leave empty to disable Sentry. Safe to omit in development and tests.
# Create a project at https://sentry.io and copy the DSN here for production.
# Backend install: pip install 'sentry-sdk[fastapi]'
# Frontend install: npm install @sentry/nextjs
SENTRY_DSN=
# Frontend browser Sentry DSN (same project is fine, or a separate browser project).
NEXT_PUBLIC_SENTRY_DSN=
# Fraction of transactions to send as performance traces (0.0–1.0).
# Default 0.1 keeps cost low. Set to 0 to disable traces entirely.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Git SHA for release tagging (set automatically in CI/Docker builds).
GIT_SHA=
NEXT_PUBLIC_GIT_SHA=

# -----------------------------------------------------------------------------
# Monitoring (Optional - Langfuse)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Enable/disable monitoring
ENABLE_LANGFUSE=false

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# Python backend
PYTHONUNBUFFERED=1
WORKERS=4

# -----------------------------------------------------------------------------
# HuggingFace (for data ingestion)
# -----------------------------------------------------------------------------
# Optional: Only needed if accessing private datasets
HUGGINGFACE_TOKEN=hf_your_token_here

# -----------------------------------------------------------------------------
# Redis (for caching and task queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_AUTH=
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Celery (for background tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=${REDIS_URL}
CELERY_BACKEND_URL=${REDIS_URL}
CELERY_PROJECT_NAME=juddges

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
API_SECRET_KEY=your-api-secret-here

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3007,http://localhost:3000

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@juddges.app

# Contact form transactional email delivery (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_INTERNAL_EMAIL=enterprise@juddges.augustyniak.ai
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=3600000

# Digest notification email sender (uses Resend API key above)
DIGEST_FROM_EMAIL=digest@juddges.app

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=juddges-app
# Image tag for production deployment (set by deploy_prod.sh, default: latest)
# JUDDGES_IMAGE_TAG=1.1.0

# Docker Hub credentials (used by build_and_push_prod.sh and deploy_prod.sh)
DOCKER_USERNAME=your-dockerhub-username
DOCKER_TOKEN=your-dockerhub-access-token

# Port mappings
FRONTEND_PORT=3007
BACKEND_PORT=8004
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Discord Notifications
# -----------------------------------------------------------------------------
# Webhook URL for build/deploy notifications
# Create a webhook in your Discord server: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
