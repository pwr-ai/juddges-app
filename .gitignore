# Juddges App .gitignore

# Environment variables
# .env.example is tracked (template with variable names only)
# All .env files are gitignored (contain actual values)
.env
.env.local
.env.*.local
.env.production
.env.secrets
.env.rls-verify

# Local git worktrees (created by superpowers:using-git-worktrees skill)
.worktrees/

# Catch nested .env files in subdirectories (e.g., backend/packages/*/.env)
**/.env
**/.env.local
**/.env.secrets

# Dependencies
node_modules/
__pycache__/
*.py[cod]
*$py.class
.Python

# Next.js
.next/
out/
build/
dist/

# Poetry
poetry.lock
.venv/
.venv-ingest/
venv/

# Python virtual environments
env/
ENV/
env.bak/
venv.bak/

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage/
coverage.json
*.cover
.hypothesis/
playwright-report/
test-results/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
tmp/
temp/
*.tmp

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Database
*.db
*.sqlite
*.sqlite3

# Supabase
.supabase/

# Docker
.docker/

# OS
Thumbs.db
.DS_Store

# Secrets
secrets/
*.pem
*.key
*.cert

# Data files (don't commit large datasets)
data/
datasets/
*.csv
*.parquet
*.jsonl

# Backups
*.bak
*.backup

# Build artifacts
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
.eggs/
*.egg-info/
*.egg
MANIFEST
dist/
downloads/
/lib/
/lib64/
parts/
sdist/
var/
wheels/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Type checking
.pytype/

# Cython debug symbols
cython_debug/
.claude/
.context/
.codex/
.playwright-mcp/
frontend/app/test-supabase/

# Celery
celerybeat-schedule
*celerybeat-schedule*

# MinIO sync (local tooling)
.minio-sync.*

# Git worktrees (local)
.worktrees/

# Test artifacts that land alongside production schema/config
backend/packages/juddges_search/config/schema/*_test.meta.json

# Deployment artifacts
.deploy-history

# Test data
test_queries.jsonl

# Runtime-generated schema metadata/backups
backend/packages/juddges_search/config/schema/*.meta.json
backend/packages/juddges_search/config/schema/*.backup_*

# Paper workspace artifacts
papers/**/.git/
papers/**/*.aux
papers/**/*.bbl
papers/**/*.blg
papers/**/*.fdb_latexmk
papers/**/*.fls
papers/**/*.log
papers/**/*.out
papers/**/*.synctex.gz
papers/**/*.toc
papers/**/main.pdf

# MkDocs build output
site/
