# =============================================================================
# Juddges App Environment Configuration - Example/Reference
# =============================================================================
# This file serves as a reference for all available configuration options.
#
# ACTUAL CONFIGURATION STRATEGY:
#   1. .env.defaults - Committed file with sensible defaults (already exists)
#   2. .env.local - Your local overrides (gitignored, create if needed)
#   3. .env.secrets - Your sensitive credentials (gitignored, create this)
#
# GETTING STARTED:
#   1. Copy this file to .env.secrets:
#      cp .env.example .env.secrets
#   2. Fill in your actual secret values in .env.secrets
#   3. Optionally create .env.local for non-secret local overrides
#
# DO NOT use this file directly - it's for reference only!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# Note: Supabase provides:
#   - PostgreSQL database with pgvector extension for semantic search
#   - Authentication and user management
#   - All vector search operations (replaces Weaviate)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Frontend uses anon key (client-side safe)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# -----------------------------------------------------------------------------
# OpenAI Configuration (for embeddings and AI features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo for cost savings

# Embedding model (for semantic search)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8004
BACKEND_API_KEY=your-backend-api-key-here

# API Rate Limits
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_PER_HOUR=1000

# -----------------------------------------------------------------------------
# Database Configuration (if running PostgreSQL separately)
# -----------------------------------------------------------------------------
# Note: Supabase provides managed PostgreSQL, so this is optional
DATABASE_URL=postgresql://user:password@localhost:5432/juddges_db

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Juddges App"
NEXT_PUBLIC_APP_URL=http://localhost:3007
NEXT_PUBLIC_API_URL=${BACKEND_URL}

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_EMBEDDINGS=true

# -----------------------------------------------------------------------------
# Monitoring (Optional - Langfuse)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Enable/disable monitoring
ENABLE_LANGFUSE=false

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# Python backend
PYTHONUNBUFFERED=1
WORKERS=4

# -----------------------------------------------------------------------------
# HuggingFace (for data ingestion)
# -----------------------------------------------------------------------------
# Optional: Only needed if accessing private datasets
HUGGINGFACE_TOKEN=hf_your_token_here

# -----------------------------------------------------------------------------
# Redis (for caching and task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Celery (for background tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
API_SECRET_KEY=your-api-secret-here

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3007,http://localhost:3000

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@juddges.app

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=juddges-app

# Port mappings
FRONTEND_PORT=3007
BACKEND_PORT=8004
REDIS_PORT=6379
