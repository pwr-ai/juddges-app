# RLS verification harness env file — copy to `.env.rls-verify` and fill in.
# This file is read by .context/scripts/run-rls-verify.sh and
# .context/scripts/verify-rls-postgrest.sh.
#
# DO NOT commit a populated .env.rls-verify (it is gitignored at the repo
# root via the existing .env pattern in .gitignore).

# === Required by both scripts ===

# Hard guard: must be exactly one of: non-prod | nonprod | staging | stage | dev | development.
# Anything else (especially `prod`/`production`/`live`) aborts the script.
SUPABASE_TARGET=non-prod

# === Required by run-rls-verify.sh (orchestrator + psql verifier) ===

# Full Postgres connection string for the NON-PROD Supabase project.
# Studio → Project Settings → Database → Connection string (URI form).
# Format: postgresql://postgres:<password>@<host>:5432/postgres
# (The script extracts user/host/password into PG* env vars internally
# so the URL never reaches `psql` argv.)
SUPABASE_DB_URL=

# A UUID that has `role='admin'` in `public.profiles` on the target DB.
# Studio → Authentication → Users → pick a user → copy the UUID, then verify
# in SQL editor: SELECT role FROM public.profiles WHERE id = '<UUID>';
ADMIN_UUID=

# === Required by verify-rls-postgrest.sh (HTTP roundtrip) ===

# Project URL (NOT the DB URL).
# Studio → Project Settings → API → "Project URL", e.g. https://abc.supabase.co
SUPABASE_URL=

# Project anon key (public, safe to share).
# Studio → Project Settings → API → "anon public" key.
ANON_KEY=

# Access token (JWT) for an authenticated NON-admin user on the target project.
# See `.context/verify-rls-migration.md` § "Minting test JWTs" for how to obtain.
# Tokens are short-lived (1 hour by default); re-mint if a run takes longer.
NON_ADMIN_JWT=

# === Optional ===

# Access token for an authenticated admin user on the target project.
# If set, verify-rls-postgrest.sh additionally tests admin INSERT via PostgREST.
# If unset, that test is SKIPped (not failed).
ADMIN_JWT=

# Override for the `prod`-substring URL guardrail (case-insensitive match on
# SUPABASE_URL or SUPABASE_DB_URL). Only set if you genuinely have a non-prod
# project whose URL contains the substring `prod` for unrelated reasons.
# I_KNOW_WHAT_IM_DOING=yes
